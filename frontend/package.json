{
  "name": "interactive-storyline-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "axios": "1.7.2",
    "tailwindcss": "3.4.4"
  },
  "devDependencies": {
    "electron": "31.0.0",
    "electron-builder": "24.13.3",
    "wait-on": "7.2.0",
    "concurrently": "8.2.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"BROWSER=none npm start\" \"npm run electron\""
  }
}
